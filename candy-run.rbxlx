-- ============================================================
-- HELPERS
-- ============================================================

local function glow(part, color, range, brightness)
	local l = Instance.new("PointLight")
	l.Color = color or part.Color; l.Range = range or 14
	l.Brightness = brightness or 0.5; l.Parent = part
end

-- Glass sheen overlay helper — gives that polished, realistic candy shine
local function addSheen(parent, size, position, color, shape, orientation)
	local s = Instance.new("Part")
	s.Size = size; s.Position = position; s.Anchored = true
	s.Color = color or Color3.fromRGB(255,255,255)
	s.Material = Enum.Material.Glass
	s.Transparency = 0.82; s.CanCollide = false
	if shape then s.Shape = shape end
	if orientation then s.Orientation = orientation end
	s.Parent = parent
	return s
end

-- ============================================================
-- CANDY PLATFORM LOADER
-- Loads candy models from ServerStorage > CandyModels folder.
-- Loads candy models from ServerStorage > CandyPieces folder.
-- All models inside that folder are auto-discovered and used as parkour platforms.
-- The script clones them, scales them, and positions them as platforms.
-- ============================================================

-- ============================================================
-- DYNAMIC CANDY MODEL LOADER
-- Scans ServerStorage > CandyPieces for all models/meshparts.
-- Each child becomes a usable platform type.
-- ============================================================

-- Search for CandyPieces folder everywhere
local candyPiecesFolder = nil
for _, name in ipairs({"CandyPieces", "candyPieces", "Candy Pieces", "candypieces", "CandyModels"}) do
	candyPiecesFolder = ServerStorage:FindFirstChild(name) or ReplicatedStorage:FindFirstChild(name)
	if candyPiecesFolder then break end
end

-- Debug: list ALL children of ServerStorage so we can see what's there
print("[CandyRun] === ServerStorage contents ===")
for _, child in ServerStorage:GetChildren() do
	print("[CandyRun]   " .. child.ClassName .. ": " .. child.Name)
end
print("[CandyRun] ===============================")

-- Build list of available candy template names from the folder
local CANDY_TYPES = {}
local candyTemplates = {} -- name -> template instance

if candyPiecesFolder then
	print("[CandyRun] Found candy folder: " .. candyPiecesFolder.Name .. " (" .. candyPiecesFolder.ClassName .. ")")
	
	-- Load every child regardless of type
	for _, child in candyPiecesFolder:GetChildren() do
		print("[CandyRun]   Child: " .. child.Name .. " (" .. child.ClassName .. ")")
		-- Accept Model, BasePart, MeshPart, or anything with descendants that have BaseParts
		if child:IsA("Model") or child:IsA("BasePart") or child:IsA("MeshPart") then
			table.insert(CANDY_TYPES, child.Name)
			candyTemplates[child.Name] = child
			print("[CandyRun]   ✓ Loaded as candy: " .. child.Name)
		elseif child:IsA("Folder") then
			-- If it's a sub-folder, check if it has parts inside
			local hasParts = false
			for _, desc in child:GetDescendants() do
				if desc:IsA("BasePart") then hasParts = true; break end
			end
			if hasParts then
				table.insert(CANDY_TYPES, child.Name)
				candyTemplates[child.Name] = child
				print("[CandyRun]   ✓ Loaded folder as candy: " .. child.Name)
			end
		end
	end
	print("[CandyRun] Total candy pieces loaded: " .. #CANDY_TYPES)
else
	warn("[CandyRun] !!! CandyPieces folder NOT FOUND in ServerStorage !!!")
	warn("[CandyRun] Make sure you have a folder called 'CandyPieces' in ServerStorage")
end

-- If no models found, add a fallback type so the game doesn't break
if #CANDY_TYPES == 0 then
	warn("[CandyRun] No candy models loaded — using pink ball fallback!")
	CANDY_TYPES = {"_fallback"}
end

-- Build a candy platform from a template model
local function buildCandyPlatform(candyName, index, pos, m)
	m = m or 1
	local model = Instance.new("Model"); model.Name = candyName .. "_" .. index

	local template = candyTemplates[candyName]
	local loaded = false

	if template then
		-- Clone the template
		local clone = template:Clone()

		-- Scale all parts by m and anchor them
		for _, part in clone:GetDescendants() do
			if part:IsA("BasePart") then
				part.Size = part.Size * m
				part.Anchored = true
			end
		end

		-- Remove grey/dark base platforms that came with the .obj import
		-- Only removes parts that are: grey AND flat AND large (base plates)
		-- Keeps ALL colorful candy parts
		local toRemove = {}
		for _, part in clone:GetDescendants() do
			if part:IsA("BasePart") then
				local c = part.Color
				local r, g, b = c.R * 255, c.G * 255, c.B * 255
				local isGrey = (math.abs(r - g) < 30 and math.abs(g - b) < 30 and r < 150)
				local sx, sy, sz = part.Size.X, part.Size.Y, part.Size.Z
				local maxDim = math.max(sx, sy, sz)
				local minDim = math.min(sx, sy, sz)
				local isFlat = (minDim < maxDim * 0.15)
				local isBig = (maxDim > 8)
				
				if isGrey and isFlat and isBig then
					table.insert(toRemove, part)
				end
			end
		end
		for _, part in ipairs(toRemove) do
			print("[CandyRun] Removed grey platform from " .. candyName .. ": " .. part.Name .. " color=(" .. math.floor(part.Color.R*255) .. "," .. math.floor(part.Color.G*255) .. "," .. math.floor(part.Color.B*255) .. ")")
			part:Destroy()
		end

		-- Debug: count remaining parts
		local partCount = 0
		for _, p in clone:GetDescendants() do
			if p:IsA("BasePart") then partCount += 1 end
		end
		print("[CandyRun] Building " .. candyName .. " with " .. partCount .. " parts at scale " .. m)

		-- Move to target position while KEEPING the model's original rotation
		-- (candy pieces are oriented correctly in Studio — don't reset that)
		local originalPivot = clone:GetPivot()
		local originalRotation = originalPivot - originalPivot.Position -- extract rotation only
		
		-- Lay down candyfloss and candycanes flat so players can walk on them
		local lowerName = string.lower(candyName)
		local shouldLayFlat = string.find(lowerName, "floss") or string.find(lowerName, "cotton")
			or string.find(lowerName, "cane") or string.find(lowerName, "candy cane")
			or string.find(lowerName, "candycane")
		if shouldLayFlat then
			originalRotation = originalRotation * CFrame.Angles(math.rad(90), 0, 0)
		end
		
		clone:PivotTo(CFrame.new(pos) * originalRotation)

		-- Make ALL parts walkable/collidable (no invisible bases)
		for _, part in clone:GetDescendants() do
			if part:IsA("BasePart") then
				part.CanCollide = true
			end
		end

		-- Find the largest part to label as "Walkable" for checkpoint detection
		local biggest, biggestVol = nil, 0
		for _, part in clone:GetDescendants() do
			if part:IsA("BasePart") then
				local vol = part.Size.X * part.Size.Y * part.Size.Z
				if vol > biggestVol then biggest = part; biggestVol = vol end
			end
		end
		if biggest then
			biggest.Name = "Walkable"
		end

		-- Reparent children into our model
		if clone:IsA("Model") then
			for _, child in clone:GetChildren() do
				child.Parent = model
			end
			clone:Destroy()
		else
			-- Single BasePart/MeshPart template
			clone.Name = "Walkable"
			clone.CanCollide = true
			clone.Parent = model
		end
		loaded = true
	end

	-- Fallback: pink ball if model wasn't found
	if not loaded then
		warn("[CandyRun] Missing candy model: " .. candyName .. " — using fallback shape")
		local main = Instance.new("Part")
		main.Name = "Walkable"
		main.Size = Vector3.new(14, 14, 14) * m
		main.Position = pos; main.Anchored = true
		main.Color = Color3.fromRGB(255, 100, 200)
		main.Material = Enum.Material.SmoothPlastic
		main.Shape = Enum.PartType.Ball
		main.TopSurface = Enum.SurfaceType.Smooth
		main.BottomSurface = Enum.SurfaceType.Smooth
		main.Parent = model
		glow(main, Color3.fromRGB(255, 100, 200), 22, 0.5)
	end

	model.Parent = mapFolder
	local walkable = model:FindFirstChild("Walkable")
	return walkable or model:FindFirstChildWhichIsA("BasePart"), model
end

-- Filter out candy-wrapped rectangular pieces from parkour selection
local function isCandyExcluded(candyName)
	local lower = string.lower(candyName)
	if string.find(lower, "wrap") or string.find(lower, "rect") or string.find(lower, "block") then
		return true
	end
	return false
end

-- Helper: pick a random candy type from the available pieces
local function randomCandy()
	for _ = 1, 30 do
		local pick = CANDY_TYPES[math.random(1, #CANDY_TYPES)]
		if not isCandyExcluded(pick) then
			return pick
		end
	end
	return CANDY_TYPES[math.random(1, #CANDY_TYPES)]
end

-- Per-candy size adjustments
local function getCandyScale(candyName, stepSize)
	local lower = string.lower(candyName)
	if string.find(lower, "floss") or string.find(lower, "cotton") then
		return 1.0  -- candyfloss stays original size
	end
	if string.find(lower, "cane") or string.find(lower, "candycane") then
		return stepSize * 0.5  -- candy canes cut in half
	end
	if string.find(lower, "donut") or string.find(lower, "doughnut") then
		return stepSize * 4.0  -- donuts quadrupled (doubled again)
	end
	if string.find(lower, "gumball") or string.find(lower, "gum ball") then
		return stepSize * 2.0  -- gumball machines doubled
	end
	if string.find(lower, "corn") or string.find(lower, "candy corn") then
		return stepSize * 1.8  -- candy corn upscaled
	end
	return stepSize
end

