  <Item class="StarterPlayer" referent="9">
    <Properties>
      <string name="Name">StarterPlayer</string>
      <float name="CameraMaxZoomDistance">40</float>
      <float name="CameraMinZoomDistance">8</float>
      <token name="CameraMode">0</token>
    </Properties>
    <Item class="StarterCharacterScripts" referent="10">
      <Properties>
        <string name="Name">StarterCharacterScripts</string>
      </Properties>
      <Item class="LocalScript" referent="11">
        <Properties>
          <string name="Name">CharacterScripts</string>
          <string name="Source"><![CDATA[--[[
	Candy Run - Character Scripts v3
	Speed 48, jump 60, DOUBLE JUMP, smooth camera, coyote time, particles
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = script.Parent.Parent
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local camera = workspace.CurrentCamera

local function isShiftLocked(): boolean
	return UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
end

-- ============================================================
-- MOVEMENT TUNING
-- ============================================================

local WALK_SPEED = 28        -- normal walking speed
local SPRINT_SPEED = 48      -- sprint speed (hold Left Ctrl)
humanoid.WalkSpeed = WALK_SPEED
humanoid.JumpPower = 60      -- strong jumps
humanoid.HipHeight = 2.2
local isSprinting = false

-- ============================================================
-- SPRINT (Hold Left Ctrl or W+Left Shift alternative)
-- ============================================================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.LeftControl then
		isSprinting = true
		if humanoid then humanoid.WalkSpeed = SPRINT_SPEED end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftControl then
		isSprinting = false
		if humanoid then humanoid.WalkSpeed = WALK_SPEED end
	end
end)

-- ============================================================
-- DOUBLE JUMP
-- ============================================================

local MAX_JUMPS = 2
local jumpsLeft = MAX_JUMPS
local canDoubleJump = false
local hasDoubleJumped = false

-- Reset jumps when landing
humanoid.StateChanged:Connect(function(_, newState)
	if newState == Enum.HumanoidStateType.Landed then
		jumpsLeft = MAX_JUMPS
		canDoubleJump = false
		hasDoubleJumped = false
	elseif newState == Enum.HumanoidStateType.Jumping then
		-- After first jump, allow double jump after a brief delay
		jumpsLeft -= 1
		if jumpsLeft > 0 then
			canDoubleJump = false
			task.delay(0.15, function()
				canDoubleJump = true
			end)
		end
	elseif newState == Enum.HumanoidStateType.Freefall then
		-- If walked off edge (didn't jump), still allow one air jump
		if jumpsLeft == MAX_JUMPS then
			jumpsLeft = 1
			canDoubleJump = true
		end
	end
end)

-- Listen for jump input while in air
UserInputService.JumpRequest:Connect(function()
	if humanoid.FloorMaterial == Enum.Material.Air and canDoubleJump and jumpsLeft > 0 and not hasDoubleJumped then
		hasDoubleJumped = true
		canDoubleJump = false
		jumpsLeft -= 1

		-- Apply upward velocity for double jump
		rootPart.AssemblyLinearVelocity = Vector3.new(
			rootPart.AssemblyLinearVelocity.X,
			humanoid.JumpPower * 1.1,  -- slightly stronger than normal jump
			rootPart.AssemblyLinearVelocity.Z
		)

		-- Double jump particles (burst of candy sparkles)
		if doubleJumpBurst then
			doubleJumpBurst:Emit(15)
		end

		-- Subtle spin effect on camera
		if not isShiftLocked() then
			task.spawn(function()
				for i = 1, 5 do
					humanoid.CameraOffset = Vector3.new(0, 0.3 * (5-i)/5, 0)
					task.wait(0.03)
				end
			end)
		end
	end
end)

-- ============================================================
-- SMOOTH CAMERA
-- ============================================================

local baseFOV = 70
local sprintFOV = 78 -- wider for faster speed

RunService.RenderStepped:Connect(function(dt)
	if not rootPart or not rootPart.Parent then return end

	local velocity = rootPart.AssemblyLinearVelocity
	local horizontalSpeed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude

	local targetFOV = baseFOV + math.clamp(horizontalSpeed / 50, 0, 1) * (sprintFOV - baseFOV)
	camera.FieldOfView += (targetFOV - camera.FieldOfView) * math.min(dt * 6, 1)

	if not isShiftLocked() then
		if humanoid.FloorMaterial ~= Enum.Material.Air and horizontalSpeed > 3 then
			local bobAmount = math.sin(tick() * 12) * 0.06
			local lateralBob = math.cos(tick() * 6) * 0.03
			humanoid.CameraOffset = humanoid.CameraOffset:Lerp(
				Vector3.new(lateralBob, bobAmount, 0), math.min(dt * 8, 1)
			)
		else
			humanoid.CameraOffset = humanoid.CameraOffset:Lerp(
				Vector3.new(0, 0, 0), math.min(dt * 5, 1)
			)
		end
	end
end)

-- ============================================================
-- LANDING SQUASH
-- ============================================================

local wasInAir = false
local airTime = 0

RunService.Heartbeat:Connect(function(dt)
	if not rootPart or not rootPart.Parent then return end

	local inAir = humanoid.FloorMaterial == Enum.Material.Air

	if inAir then
		airTime += dt
		wasInAir = true
	elseif wasInAir then
		local landingForce = math.clamp(airTime * 2, 0.1, 1)
		if not isShiftLocked() then
			humanoid.CameraOffset = Vector3.new(0, -landingForce * 0.6, 0)
		end
		airTime = 0
		wasInAir = false
	end
end)

-- ============================================================
-- COYOTE TIME + JUMP BUFFER
-- ============================================================

local COYOTE_TIME = 0.12
local JUMP_BUFFER_TIME = 0.15
local lastGroundedTime = 0
local lastJumpPressTime = -1
local hasUsedCoyote = false

UserInputService.JumpRequest:Connect(function()
	lastJumpPressTime = tick()
end)

RunService.Heartbeat:Connect(function()
	if not humanoid or not humanoid.Parent then return end

	local grounded = humanoid.FloorMaterial ~= Enum.Material.Air

	if grounded then
		lastGroundedTime = tick()
		hasUsedCoyote = false
	end

	local timeSinceGrounded = tick() - lastGroundedTime
	local timeSinceJumpPress = tick() - lastJumpPressTime

	if not grounded and not hasUsedCoyote
		and timeSinceGrounded < COYOTE_TIME
		and timeSinceJumpPress < JUMP_BUFFER_TIME
	then
		hasUsedCoyote = true
		humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		lastJumpPressTime = -1
	end

	if grounded and timeSinceJumpPress < JUMP_BUFFER_TIME then
		humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		lastJumpPressTime = -1
	end
end)

-- ============================================================
-- CANDY TRAIL
-- ============================================================

local trail = Instance.new("ParticleEmitter")
trail.Name = "CandyTrail"
trail.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 150, 200)),
	ColorSequenceKeypoint.new(0.5, Color3.fromRGB(200, 130, 255)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(130, 200, 255)),
})
trail.Size = NumberSequence.new({
	NumberSequenceKeypoint.new(0, 0.4),
	NumberSequenceKeypoint.new(0.5, 0.2),
	NumberSequenceKeypoint.new(1, 0),
})
trail.Transparency = NumberSequence.new({
	NumberSequenceKeypoint.new(0, 0.4),
	NumberSequenceKeypoint.new(0.5, 0.6),
	NumberSequenceKeypoint.new(1, 1),
})
trail.Lifetime = NumberRange.new(0.3, 0.7)
trail.Rate = 0
trail.Speed = NumberRange.new(0.5, 2)
trail.SpreadAngle = Vector2.new(15, 15)
trail.Rotation = NumberRange.new(-180, 180)
trail.RotSpeed = NumberRange.new(-60, 60)
trail.Acceleration = Vector3.new(0, -2, 0)
trail.Parent = rootPart

RunService.Heartbeat:Connect(function()
	if not rootPart or not rootPart.Parent then return end
	local velocity = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude
	trail.Rate = if speed > 4 then math.clamp(speed * 0.6, 0, 25) else 0
end)

-- ============================================================
-- JUMP PARTICLES
-- ============================================================

local jumpBurst = Instance.new("ParticleEmitter")
jumpBurst.Name = "JumpBurst"
jumpBurst.Color = ColorSequence.new(Color3.fromRGB(255, 220, 100))
jumpBurst.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)})
jumpBurst.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.2), NumberSequenceKeypoint.new(1, 1)})
jumpBurst.Lifetime = NumberRange.new(0.2, 0.4)
jumpBurst.Rate = 0
jumpBurst.Speed = NumberRange.new(5, 10)
jumpBurst.SpreadAngle = Vector2.new(60, 60)
jumpBurst.Acceleration = Vector3.new(0, -20, 0)
jumpBurst.Parent = rootPart

humanoid.Jumping:Connect(function()
	jumpBurst:Emit(8)
end)

-- ============================================================
-- DOUBLE JUMP PARTICLES (distinct from regular jump)
-- ============================================================

doubleJumpBurst = Instance.new("ParticleEmitter")
doubleJumpBurst.Name = "DoubleJumpBurst"
doubleJumpBurst.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 255)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 200, 255)),
})
doubleJumpBurst.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1.5), NumberSequenceKeypoint.new(1, 0)})
doubleJumpBurst.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.1), NumberSequenceKeypoint.new(1, 1)})
doubleJumpBurst.Lifetime = NumberRange.new(0.3, 0.5)
doubleJumpBurst.Rate = 0
doubleJumpBurst.Speed = NumberRange.new(8, 15)
doubleJumpBurst.SpreadAngle = Vector2.new(80, 80)
doubleJumpBurst.Acceleration = Vector3.new(0, -25, 0)
doubleJumpBurst.Parent = rootPart

-- ============================================================
-- LAND PARTICLES
-- ============================================================

local landBurst = Instance.new("ParticleEmitter")
landBurst.Name = "LandBurst"
landBurst.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 180, 220)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 130, 255)),
})
landBurst.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.8), NumberSequenceKeypoint.new(1, 0)})
landBurst.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.3), NumberSequenceKeypoint.new(1, 1)})
landBurst.Lifetime = NumberRange.new(0.3, 0.5)
landBurst.Rate = 0
landBurst.Speed = NumberRange.new(3, 8)
landBurst.SpreadAngle = Vector2.new(80, 80)
landBurst.Acceleration = Vector3.new(0, -15, 0)
landBurst.Parent = rootPart

humanoid.StateChanged:Connect(function(_, newState)
	if newState == Enum.HumanoidStateType.Landed then
		landBurst:Emit(12)
	end
end)

print("[CandyRun] Character loaded! Speed: 48, Double Jump: ON")
]]></string>
        </Properties>
      </Item>
    </Item>
    <Item class="StarterPlayerScripts" referent="12">
      <Properties>
        <string name="Name">StarterPlayerScripts</string>
      </Properties>
      <Item class="LocalScript" referent="13">
        <Properties>
          <string name="Name">Client</string>
          <string name="Source"><![CDATA[--[[
	Candy Run - Client HUD & Game Feel v3
	Timer starts/restarts on spawn & respawn, smooth effects, respawn overlay
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local timerEvent = ReplicatedStorage:WaitForChild("TimerUpdate")
local candyCollectedEvent = ReplicatedStorage:WaitForChild("CandyCollected")
local candyUpdateEvent = ReplicatedStorage:WaitForChild("CandyUpdate")
local purchaseEvent = ReplicatedStorage:WaitForChild("PurchaseItem")
local respawnEvent = ReplicatedStorage:WaitForChild("RespawnTimer")
local timerStartEvent = ReplicatedStorage:WaitForChild("TimerStart")
local dailySpinEvent = ReplicatedStorage:WaitForChild("DailySpin", 10)
local trailSpinResultEvent = ReplicatedStorage:WaitForChild("TrailSpinResult", 10)

-- ============================================================
-- HUD
-- ============================================================

local hudGui = Instance.new("ScreenGui")
hudGui.Name = "CandyRunHUD"
hudGui.ResetOnSpawn = false
hudGui.IgnoreGuiInset = false
hudGui.Enabled = false
hudGui.Parent = playerGui

local timerFrame = Instance.new("Frame")
timerFrame.Size = UDim2.fromScale(0.18, 0.055)
timerFrame.Position = UDim2.fromScale(0.41, 0.02)
timerFrame.BackgroundColor3 = Color3.fromRGB(20, 10, 30)
timerFrame.BackgroundTransparency = 0.4
timerFrame.Parent = hudGui

Instance.new("UICorner", timerFrame).CornerRadius = UDim.new(0, 12)

local timerStroke = Instance.new("UIStroke")
timerStroke.Color = Color3.fromRGB(255, 150, 200)
timerStroke.Thickness = 1.5; timerStroke.Transparency = 0.3
timerStroke.Parent = timerFrame

local timerLabel = Instance.new("TextLabel")
timerLabel.Size = UDim2.fromScale(0.9, 0.8)
timerLabel.Position = UDim2.fromScale(0.05, 0.1)
timerLabel.BackgroundTransparency = 1
timerLabel.Text = "⏱️ 0:00.0"
timerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
timerLabel.TextScaled = true
timerLabel.Font = Enum.Font.FredokaOne
timerLabel.Parent = timerFrame

local candyFrame = Instance.new("Frame")
candyFrame.Size = UDim2.fromScale(0.12, 0.055)
candyFrame.Position = UDim2.fromScale(0.86, 0.02)
candyFrame.BackgroundColor3 = Color3.fromRGB(20, 10, 30)
candyFrame.BackgroundTransparency = 0.4
candyFrame.Parent = hudGui

Instance.new("UICorner", candyFrame).CornerRadius = UDim.new(0, 12)

local candyStroke = Instance.new("UIStroke")
candyStroke.Color = Color3.fromRGB(255, 200, 100)
candyStroke.Thickness = 1.5; candyStroke.Transparency = 0.3
candyStroke.Parent = candyFrame

local candyLabel = Instance.new("TextLabel")
candyLabel.Size = UDim2.fromScale(0.9, 0.8)
candyLabel.Position = UDim2.fromScale(0.05, 0.1)
candyLabel.BackgroundTransparency = 1
candyLabel.Text = "🍬 0"
candyLabel.TextColor3 = Color3.fromRGB(255, 220, 100)
candyLabel.TextScaled = true
candyLabel.Font = Enum.Font.FredokaOne
candyLabel.Parent = candyFrame

-- ============================================================
-- HEALTH BAR (top center, styled like the model in ServerStorage)
-- First tries to clone the HealthBar ScreenGui/Model from ServerStorage.
-- If not found, creates a custom candy-themed health bar.
-- ============================================================

local healthBarFrame = Instance.new("Frame")
healthBarFrame.Name = "HealthBar"
healthBarFrame.Size = UDim2.fromScale(0.3, 0.035)
healthBarFrame.Position = UDim2.fromScale(0.35, 0.08)
healthBarFrame.BackgroundColor3 = Color3.fromRGB(30, 15, 15)
healthBarFrame.BackgroundTransparency = 0.3
healthBarFrame.Parent = hudGui
Instance.new("UICorner", healthBarFrame).CornerRadius = UDim.new(0, 10)

local hbStroke = Instance.new("UIStroke")
hbStroke.Color = Color3.fromRGB(200, 50, 80); hbStroke.Thickness = 2
hbStroke.Parent = healthBarFrame

-- Fill bar (green → yellow → red based on health)
local healthFill = Instance.new("Frame")
healthFill.Name = "Fill"
healthFill.Size = UDim2.fromScale(1, 1)
healthFill.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
healthFill.Parent = healthBarFrame
Instance.new("UICorner", healthFill).CornerRadius = UDim.new(0, 10)

-- Health text overlay
local healthText = Instance.new("TextLabel")
healthText.Size = UDim2.fromScale(1, 1)
healthText.BackgroundTransparency = 1
healthText.Text = "❤️ 100/100"
healthText.TextColor3 = Color3.fromRGB(255, 255, 255)
healthText.TextScaled = true
healthText.Font = Enum.Font.FredokaOne
healthText.Parent = healthBarFrame
Instance.new("UIStroke", healthText).Color = Color3.fromRGB(0,0,0)

-- Update health bar from humanoid
local function updateHealthBar()
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
	TweenService:Create(healthFill, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
		Size = UDim2.fromScale(pct, 1),
	}):Play()

	-- Color: green → yellow → red
	local color
	if pct > 0.5 then
		local t = (pct - 0.5) * 2
		color = Color3.fromRGB(255 - t*175, 220, 80)
	else
		local t = pct * 2
		color = Color3.fromRGB(220, t*220, 80 * t)
	end
	TweenService:Create(healthFill, TweenInfo.new(0.3), {BackgroundColor3 = color}):Play()
	healthText.Text = "❤️ " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
end

local function hookHealthBar(char)
	local hum = char:WaitForChild("Humanoid", 10)
	if hum then
		hum.HealthChanged:Connect(updateHealthBar)
		updateHealthBar()
	end
end

if player.Character then hookHealthBar(player.Character) end
player.CharacterAdded:Connect(hookHealthBar)

-- ============================================================
-- TIMER STATE
-- ============================================================

local gameStarted = false
local startTime = 0
local candiesCollected = 0
local hasWon = false
local timerRunning = false

local function startTimer()
	startTime = tick()
	candiesCollected = 0
	candyLabel.Text = "🍬 0"
	hasWon = false
	gameStarted = true
	hudGui.Enabled = true

	if not timerRunning then
		timerRunning = true
		task.spawn(function()
			while gameStarted do
				local elapsed = tick() - startTime
				local minutes = math.floor(elapsed / 60)
				local seconds = elapsed % 60
				timerLabel.Text = string.format("⏱️ %d:%04.1f", minutes, seconds)
				task.wait(0.05)
			end
			timerRunning = false
		end)
	end
end

-- Timer starts when server tells us (play button or respawn)
timerStartEvent.OnClientEvent:Connect(function()
	startTime = tick()
	if not gameStarted then
		startTimer()
	end
end)

-- Also start when start screen disappears
task.spawn(function()
	while playerGui:FindFirstChild("CandyRunStartScreen") do
		task.wait(0.1)
	end
	-- Start screen gone = ready
	if not gameStarted then
		startTimer()
	end

	-- HUD slide in
	timerFrame.Position = UDim2.fromScale(0.41, -0.08)
	candyFrame.Position = UDim2.fromScale(0.86, -0.08)
	TweenService:Create(timerFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.41, 0.02),
	}):Play()
	TweenService:Create(candyFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out, 0, false, 0.1), {
		Position = UDim2.fromScale(0.86, 0.02),
	}):Play()
end)

-- ============================================================
-- CANDY COLLECTION
-- ============================================================

candyCollectedEvent.OnClientEvent:Connect(function()
	candiesCollected += 1
	candyLabel.Text = "🍬 " .. candiesCollected

	TweenService:Create(candyFrame, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(0.15, 0.07),
		BackgroundColor3 = Color3.fromRGB(255, 220, 50),
	}):Play()
	task.wait(0.08)
	TweenService:Create(candyFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(0.12, 0.055),
		BackgroundColor3 = Color3.fromRGB(20, 10, 30),
	}):Play()

	local plusOne = Instance.new("TextLabel")
	plusOne.Size = UDim2.fromScale(0.06, 0.04)
	plusOne.Position = UDim2.fromScale(0.89, 0.07)
	plusOne.BackgroundTransparency = 1
	plusOne.Text = "+1"
	plusOne.TextColor3 = Color3.fromRGB(255, 220, 100)
	plusOne.TextScaled = true
	plusOne.Font = Enum.Font.FredokaOne
	plusOne.Parent = hudGui

	TweenService:Create(plusOne, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.fromScale(0.89, -0.02),
		TextTransparency = 1,
	}):Play()
	task.delay(0.7, function() plusOne:Destroy() end)
end)

-- Sync candy balance from server
candyUpdateEvent.OnClientEvent:Connect(function(newBalance)
	candiesCollected = newBalance
	candyLabel.Text = "🍬 " .. candiesCollected
end)

-- Purchase feedback
purchaseEvent.OnClientEvent:Connect(function(status, itemName, price, balance)
	if status == "success" then
		-- Green flash + text
		local msg = Instance.new("TextLabel")
		msg.Size = UDim2.fromScale(0.3, 0.06)
		msg.Position = UDim2.fromScale(0.35, 0.45)
		msg.BackgroundColor3 = Color3.fromRGB(30, 100, 40)
		msg.BackgroundTransparency = 0.3
		msg.Text = "✅ Bought " .. itemName .. "! (-" .. price .. " 🍬)"
		msg.TextColor3 = Color3.fromRGB(100, 255, 120)
		msg.TextScaled = true; msg.Font = Enum.Font.FredokaOne
		msg.Parent = hudGui
		Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 10)
		TweenService:Create(msg, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromScale(0.35, 0.38),
			TextTransparency = 1,
			BackgroundTransparency = 1,
		}):Play()
		task.delay(2.2, function() msg:Destroy() end)
	elseif status == "fail" then
		-- Red flash
		local msg = Instance.new("TextLabel")
		msg.Size = UDim2.fromScale(0.3, 0.06)
		msg.Position = UDim2.fromScale(0.35, 0.45)
		msg.BackgroundColor3 = Color3.fromRGB(100, 30, 30)
		msg.BackgroundTransparency = 0.3
		msg.Text = "❌ Need " .. price .. " 🍬 for " .. itemName .. " (have " .. balance .. ")"
		msg.TextColor3 = Color3.fromRGB(255, 100, 100)
		msg.TextScaled = true; msg.Font = Enum.Font.FredokaOne
		msg.Parent = hudGui
		Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 10)
		TweenService:Create(msg, TweenInfo.new(2.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromScale(0.35, 0.38),
			TextTransparency = 1,
			BackgroundTransparency = 1,
		}):Play()
		task.delay(2.7, function() msg:Destroy() end)
	end
end)

