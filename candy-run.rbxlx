local spinRequestEvent = ReplicatedStorage:WaitForChild("SpinRequest", 10)

if dailySpinEvent then
	local spinGuiOpen = false
	local spinGui = nil

	local SPIN_REWARDS_CLIENT = {
		{name = "50 Candy", icon = "🍬", color = Color3.fromRGB(255, 200, 50)},
		{name = "2x Speed 15m", icon = "⚡", color = Color3.fromRGB(80, 200, 255)},
		{name = "25 Candy", icon = "🍬", color = Color3.fromRGB(200, 255, 100)},
		{name = "Low Gravity 10m", icon = "🌀", color = Color3.fromRGB(180, 80, 255)},
		{name = "100 Candy", icon = "💰", color = Color3.fromRGB(255, 215, 0)},
		{name = "Trail: Rainbow", icon = "🌈", color = Color3.fromRGB(255, 100, 200)},
		{name = "500 Candy", icon = "💎", color = Color3.fromRGB(100, 255, 255)},
		{name = "JACKPOT: VIP", icon = "👑", color = Color3.fromRGB(255, 50, 50)},
	}

	local function createSpinGui()
		if spinGui then spinGui:Destroy() end

		spinGui = Instance.new("ScreenGui")
		spinGui.Name = "DailySpinGui"; spinGui.IgnoreGuiInset = true
		spinGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling; spinGui.Parent = playerGui

		-- Dark overlay
		local overlay = Instance.new("Frame"); overlay.Size = UDim2.fromScale(1,1)
		overlay.BackgroundColor3 = Color3.fromRGB(0,0,0); overlay.BackgroundTransparency = 0.45
		overlay.ZIndex = 100; overlay.Parent = spinGui

		-- Main popup (large, takes most of the screen)
		local popup = Instance.new("Frame"); popup.Name = "Popup"
		popup.Size = UDim2.fromScale(0.65, 0.88)
		popup.AnchorPoint = Vector2.new(0.5, 0.5)
		popup.Position = UDim2.fromScale(0.5, 0.5)
		popup.BackgroundColor3 = Color3.fromRGB(35, 10, 55); popup.BorderSizePixel = 0
		popup.ZIndex = 101; popup.Parent = spinGui
		Instance.new("UICorner", popup).CornerRadius = UDim.new(0, 24)
		local pStroke = Instance.new("UIStroke"); pStroke.Color = Color3.fromRGB(255,180,50)
		pStroke.Thickness = 4; pStroke.Parent = popup

		-- Title
		local title = Instance.new("TextLabel")
		title.Size = UDim2.fromScale(0.7, 0.06)
		title.AnchorPoint = Vector2.new(0.5, 0)
		title.Position = UDim2.fromScale(0.5, 0.015)
		title.BackgroundTransparency = 1
		title.Text = "🎡 DAILY SPIN 🎡"
		title.TextColor3 = Color3.fromRGB(255,220,80); title.TextScaled = true
		title.Font = Enum.Font.FredokaOne; title.ZIndex = 102; title.Parent = popup
		Instance.new("UIStroke", title).Color = Color3.fromRGB(200,140,20)

		-- Close button (red X)
		local closeBtn = Instance.new("TextButton")
		closeBtn.Size = UDim2.fromOffset(40, 40)
		closeBtn.Position = UDim2.new(1, -48, 0, 8)
		closeBtn.BackgroundColor3 = Color3.fromRGB(200,40,40); closeBtn.Text = "✕"
		closeBtn.TextColor3 = Color3.fromRGB(255,255,255); closeBtn.TextSize = 24
		closeBtn.Font = Enum.Font.GothamBold; closeBtn.ZIndex = 103; closeBtn.Parent = popup
		Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 20)
		closeBtn.MouseButton1Click:Connect(function()
			spinGui:Destroy(); spinGui = nil; spinGuiOpen = false
		end)

		-- ========== BIG DISC WHEEL ==========
		-- Square container
		local wheelContainer = Instance.new("Frame"); wheelContainer.Name = "WheelContainer"
		wheelContainer.Size = UDim2.fromScale(0.72, 0.72)
		wheelContainer.AnchorPoint = Vector2.new(0.5, 0)
		wheelContainer.Position = UDim2.fromScale(0.5, 0.08)
		wheelContainer.BackgroundTransparency = 1; wheelContainer.ZIndex = 102
		wheelContainer.SizeConstraint = Enum.SizeConstraint.RelativeXX
		wheelContainer.Parent = popup

		-- Gold outer rim (static circle)
		local outerRing = Instance.new("Frame")
		outerRing.Size = UDim2.fromScale(1.04, 1.04)
		outerRing.AnchorPoint = Vector2.new(0.5, 0.5)
		outerRing.Position = UDim2.fromScale(0.5, 0.5)
		outerRing.BackgroundColor3 = Color3.fromRGB(255, 215, 0); outerRing.ZIndex = 102
		outerRing.Parent = wheelContainer
		Instance.new("UICorner", outerRing).CornerRadius = UDim.new(1, 0)

		-- The spinning disc: CIRCULAR with ClipsDescendants
		-- Rectangular segments inside get clipped into pie/wedge shapes!
		local wheelRotator = Instance.new("Frame"); wheelRotator.Name = "WheelRotator"
		wheelRotator.Size = UDim2.fromScale(0.96, 0.96)
		wheelRotator.AnchorPoint = Vector2.new(0.5, 0.5)
		wheelRotator.Position = UDim2.fromScale(0.5, 0.5)
		wheelRotator.BackgroundColor3 = Color3.fromRGB(240, 235, 220)
		wheelRotator.ZIndex = 103; wheelRotator.ClipsDescendants = true
		wheelRotator.Parent = wheelContainer
		Instance.new("UICorner", wheelRotator).CornerRadius = UDim.new(1, 0)

		-- Build wedge segments: wide rectangles anchored at center, clipped by circle
		local numSegs = #SPIN_REWARDS_CLIENT
		local segAngle = 360 / numSegs
		-- Width of each segment: needs to cover the full arc angle
		-- For 8 segments (45° each): tan(22.5°) ≈ 0.414, so width ≈ 0.414 * height
		-- Segment goes from center to edge = 0.5 of wheel height
		local segWidth = math.tan(math.rad(segAngle / 2)) * 2 -- relative to height

		for i, rw in ipairs(SPIN_REWARDS_CLIENT) do
			local angle = (i - 1) * segAngle

			-- Colored wedge (tall rectangle from center to edge, circle clips it into wedge)
			local segFrame = Instance.new("Frame")
			segFrame.Size = UDim2.fromScale(segWidth * 0.5, 0.5)
			segFrame.AnchorPoint = Vector2.new(0.5, 1) -- anchor at bottom-center = wheel center
			segFrame.Position = UDim2.fromScale(0.5, 0.5)
			segFrame.Rotation = angle
			segFrame.BackgroundColor3 = rw.color; segFrame.BorderSizePixel = 0
			segFrame.ZIndex = 104; segFrame.Parent = wheelRotator

			-- Icon near the rim
			local iconLbl = Instance.new("TextLabel")
			iconLbl.Size = UDim2.fromScale(0.9, 0.25)
			iconLbl.AnchorPoint = Vector2.new(0.5, 0)
			iconLbl.Position = UDim2.fromScale(0.5, 0.05)
			iconLbl.BackgroundTransparency = 1; iconLbl.Text = rw.icon
			iconLbl.TextScaled = true; iconLbl.Font = Enum.Font.FredokaOne
			iconLbl.TextColor3 = Color3.fromRGB(255,255,255); iconLbl.ZIndex = 105
			iconLbl.Parent = segFrame

			-- Reward name below icon
			local nameLbl = Instance.new("TextLabel")
			nameLbl.Size = UDim2.fromScale(0.85, 0.5)
			nameLbl.AnchorPoint = Vector2.new(0.5, 0)
			nameLbl.Position = UDim2.fromScale(0.5, 0.28)
			nameLbl.BackgroundTransparency = 1; nameLbl.Text = rw.name
			nameLbl.TextScaled = true; nameLbl.Font = Enum.Font.FredokaOne
			nameLbl.TextColor3 = Color3.fromRGB(255,255,255); nameLbl.TextWrapped = true
			nameLbl.ZIndex = 105; nameLbl.Parent = segFrame
			local ns = Instance.new("UIStroke"); ns.Color = Color3.fromRGB(0,0,0)
			ns.Thickness = 1.5; ns.Parent = nameLbl

			-- Divider line at segment boundary
			local divLine = Instance.new("Frame")
			divLine.Size = UDim2.fromScale(0.008, 0.5)
			divLine.AnchorPoint = Vector2.new(0.5, 1)
			divLine.Position = UDim2.fromScale(0.5, 0.5)
			divLine.Rotation = angle - segAngle / 2
			divLine.BackgroundColor3 = Color3.fromRGB(30, 10, 45); divLine.BorderSizePixel = 0
			divLine.ZIndex = 106; divLine.Parent = wheelRotator
		end

		-- Center hub (gold circle, on top of everything)
		local hub = Instance.new("Frame")
		hub.Size = UDim2.fromScale(0.16, 0.16)
		hub.AnchorPoint = Vector2.new(0.5, 0.5)
		hub.Position = UDim2.fromScale(0.5, 0.5)
		hub.BackgroundColor3 = Color3.fromRGB(255, 215, 0); hub.ZIndex = 108
		hub.Parent = wheelContainer
		Instance.new("UICorner", hub).CornerRadius = UDim.new(1, 0)
		local hubStroke = Instance.new("UIStroke")
		hubStroke.Color = Color3.fromRGB(180, 140, 30); hubStroke.Thickness = 3; hubStroke.Parent = hub
		local hubText = Instance.new("TextLabel")
		hubText.Size = UDim2.fromScale(1,1); hubText.BackgroundTransparency = 1
		hubText.Text = "🎡"; hubText.TextScaled = true; hubText.Font = Enum.Font.FredokaOne
		hubText.ZIndex = 109; hubText.Parent = hub

		-- Pointer (red arrow at top, static)
		local pointerLbl = Instance.new("TextLabel")
		pointerLbl.Size = UDim2.fromOffset(44, 52)
		pointerLbl.AnchorPoint = Vector2.new(0.5, 1)
		pointerLbl.Position = UDim2.fromScale(0.5, 0.02)
		pointerLbl.BackgroundTransparency = 1; pointerLbl.Text = "🔻"
		pointerLbl.TextScaled = true; pointerLbl.ZIndex = 110
		pointerLbl.Parent = wheelContainer

		-- ========== IDLE ROTATION ==========
		local idleConnection
		local wheelAngle = 0
		idleConnection = RunService.Heartbeat:Connect(function(dt)
			if not spinGui or not spinGui.Parent then
				if idleConnection then idleConnection:Disconnect() end; return
			end
			wheelAngle = (wheelAngle + dt * 12) % 360
			wheelRotator.Rotation = wheelAngle
		end)

		-- ========== BUTTONS ==========
		local btnFrame = Instance.new("Frame")
		btnFrame.Size = UDim2.fromScale(0.85, 0.1)
		btnFrame.AnchorPoint = Vector2.new(0.5, 0)
		btnFrame.Position = UDim2.fromScale(0.5, 0.87)
		btnFrame.BackgroundTransparency = 1; btnFrame.ZIndex = 102; btnFrame.Parent = popup

		local freeBtn = Instance.new("TextButton")
		freeBtn.Size = UDim2.fromScale(0.47, 1)
		freeBtn.Position = UDim2.fromScale(0, 0)
		freeBtn.BackgroundColor3 = Color3.fromRGB(60, 190, 70)
		freeBtn.Text = "🎁 Free Spin"; freeBtn.TextColor3 = Color3.fromRGB(255,255,255)
		freeBtn.TextScaled = true; freeBtn.Font = Enum.Font.FredokaOne
		freeBtn.ZIndex = 103; freeBtn.Parent = btnFrame
		Instance.new("UICorner", freeBtn).CornerRadius = UDim.new(0, 16)
		Instance.new("UIStroke", freeBtn).Color = Color3.fromRGB(40, 140, 40)

		local paidBtn = Instance.new("TextButton")
		paidBtn.Size = UDim2.fromScale(0.47, 1)
		paidBtn.Position = UDim2.fromScale(0.53, 0)
		paidBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 40)
		paidBtn.Text = "💎 Spin (R$49)"; paidBtn.TextColor3 = Color3.fromRGB(255,255,255)
		paidBtn.TextScaled = true; paidBtn.Font = Enum.Font.FredokaOne
		paidBtn.ZIndex = 103; paidBtn.Parent = btnFrame
		Instance.new("UICorner", paidBtn).CornerRadius = UDim.new(0, 16)
		Instance.new("UIStroke", paidBtn).Color = Color3.fromRGB(200, 120, 20)

		-- Result bar (hidden until spin)
		local resultFrame = Instance.new("Frame"); resultFrame.Name = "ResultFrame"
		resultFrame.Size = UDim2.fromScale(0.85, 0.06)
		resultFrame.AnchorPoint = Vector2.new(0.5, 0)
		resultFrame.Position = UDim2.fromScale(0.5, 0.8)
		resultFrame.BackgroundColor3 = Color3.fromRGB(25, 8, 40); resultFrame.BackgroundTransparency = 0.2
		resultFrame.Visible = false; resultFrame.ZIndex = 102; resultFrame.Parent = popup
		Instance.new("UICorner", resultFrame).CornerRadius = UDim.new(0, 12)
		local resultLbl = Instance.new("TextLabel")
		resultLbl.Size = UDim2.fromScale(1,1); resultLbl.BackgroundTransparency = 1
		resultLbl.TextColor3 = Color3.fromRGB(255,220,80); resultLbl.TextScaled = true
		resultLbl.Font = Enum.Font.FredokaOne; resultLbl.ZIndex = 103; resultLbl.Parent = resultFrame

		-- Confetti
		local function showConfetti()
			for ci = 1, 50 do
				local c = Instance.new("TextLabel")
				c.Text = ({"🍬","🎉","✨","⭐","🌈","💎","🎊","🏆"})[math.random(1,8)]
				c.TextSize = math.random(18, 34); c.BackgroundTransparency = 1
				c.Size = UDim2.fromOffset(34,34)
				c.Position = UDim2.fromScale(0.5, 0.45); c.ZIndex = 112; c.Parent = popup
				local a = math.random() * math.pi * 2
				local d = math.random(20, 50) / 100
				TweenService:Create(c, TweenInfo.new(math.random(10,18)/10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Position = UDim2.fromScale(0.5+math.cos(a)*d, 0.45+math.sin(a)*d),
					TextTransparency = 1, Rotation = math.random(-360,360),
				}):Play()
				task.delay(2.5, function() if c then c:Destroy() end end)
			end
		end

		-- Win sound
		local winSound = Instance.new("Sound")
		winSound.SoundId = "rbxassetid://5619828673"; winSound.Volume = 1.5; winSound.Parent = playerGui

		-- Tick sound
		local tickSound = Instance.new("Sound")
		tickSound.SoundId = "rbxassetid://6732690176"; tickSound.Volume = 0.6; tickSound.Parent = playerGui

		-- ========== SPIN ANIMATION ==========
		local spinning = false
		local function doSpinAnimation(winIdx, rewardName, rewardIcon)
			if spinning then return end
			spinning = true
			freeBtn.Active = false; freeBtn.BackgroundTransparency = 0.5
			paidBtn.Active = false; paidBtn.BackgroundTransparency = 0.5
			resultFrame.Visible = false

			if idleConnection then idleConnection:Disconnect(); idleConnection = nil end

			local segDeg = 360 / #SPIN_REWARDS_CLIENT
			local targetAngle = (winIdx - 1) * segDeg + segDeg / 2
			local startAngle = wheelAngle
			local totalSpin = math.random(6, 9) * 360 + targetAngle
			local duration = 5.5
			local startT = tick()
			local lastSegIdx = -1

			while true do
				local elapsed = tick() - startT
				if elapsed >= duration then break end
				local t = elapsed / duration
				local eased = 1 - (1 - t) ^ 4 -- quartic for smoother deceleration
				wheelAngle = startAngle + totalSpin * eased
				wheelRotator.Rotation = wheelAngle

				-- Tick sound on segment change
				local segIdx = math.floor(wheelAngle / segDeg) % #SPIN_REWARDS_CLIENT
				if segIdx ~= lastSegIdx then
					lastSegIdx = segIdx
					tickSound:Play()
				end
				task.wait(0.016)
			end

			wheelAngle = startAngle + totalSpin
			wheelRotator.Rotation = wheelAngle

			-- Settle wobble
			for w = 1, 3 do
				local amt = 4 / w
				TweenService:Create(wheelRotator, TweenInfo.new(0.12, Enum.EasingStyle.Sine), {
					Rotation = wheelAngle + amt
				}):Play(); task.wait(0.12)
				TweenService:Create(wheelRotator, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {
					Rotation = wheelAngle - amt * 0.4
				}):Play(); task.wait(0.15)
			end
			TweenService:Create(wheelRotator, TweenInfo.new(0.1), {Rotation = wheelAngle}):Play()
			task.wait(0.15)

			-- Show result
			resultFrame.Visible = true
			resultLbl.Text = rewardIcon .. " You won: " .. rewardName .. "! " .. rewardIcon
			winSound:Play(); showConfetti()

			task.delay(2.5, function()
				spinning = false
				if freeBtn and freeBtn.Parent then
					freeBtn.Active = true; freeBtn.BackgroundTransparency = 0
					paidBtn.Active = true; paidBtn.BackgroundTransparency = 0
				end
				if spinGui and spinGui.Parent and not idleConnection then
					idleConnection = RunService.Heartbeat:Connect(function(dt)
						if not spinGui or not spinGui.Parent then
							if idleConnection then idleConnection:Disconnect() end; return
						end
						wheelAngle = (wheelAngle + dt * 12) % 360
						wheelRotator.Rotation = wheelAngle
					end)
				end
			end)
		end

		freeBtn.MouseButton1Click:Connect(function()
			if spinning then return end
			if spinRequestEvent then spinRequestEvent:FireServer("free") end
		end)
		paidBtn.MouseButton1Click:Connect(function()
			if spinning then return end
			if spinRequestEvent then spinRequestEvent:FireServer("paid") end
		end)

		return {doSpinAnimation = doSpinAnimation}
	end

	-- Handle server messages
	local guiHandlers = nil
	dailySpinEvent.OnClientEvent:Connect(function(msgType, ...)
		if msgType == "open" then
			-- Open the GUI
			if not spinGuiOpen then
				spinGuiOpen = true
				guiHandlers = createSpinGui()
			end
		elseif msgType == "result" then
			-- Spin result from server
			local winIdx, rewardName, rewardIcon = ...
			if guiHandlers and guiHandlers.doSpinAnimation then
				guiHandlers.doSpinAnimation(winIdx, rewardName, rewardIcon)
			else
				-- GUI not open, show quick notification
				local msg = Instance.new("TextLabel")
				msg.Size = UDim2.fromScale(0.4, 0.1)
				msg.Position = UDim2.fromScale(0.3, 0.35)
				msg.BackgroundColor3 = Color3.fromRGB(40, 20, 60)
				msg.BackgroundTransparency = 0.15
				msg.Text = "🎡 " .. (rewardIcon or "🎁") .. " " .. (rewardName or "Prize") .. "! 🎡"
				msg.TextColor3 = Color3.fromRGB(255, 220, 80)
				msg.TextScaled = true; msg.Font = Enum.Font.FredokaOne
				msg.Parent = hudGui
				Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 14)
				task.delay(3, function()
					TweenService:Create(msg, TweenInfo.new(1), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
					task.delay(1.2, function() msg:Destroy() end)
				end)
			end
		elseif msgType == "cooldown" then
			local timeLeft = ...
			if spinGui and spinGui.Parent then
				-- Show cooldown in the GUI
				local popup = spinGui:FindFirstChild("Popup")
				if popup then
					local rf = popup:FindFirstChild("ResultFrame")
					if rf then
						rf.Visible = true
						rf:FindFirstChildWhichIsA("TextLabel").Text = "⏰ Next free spin in: " .. (timeLeft or "?")
					end
				end
			end
		end
	end)
end

-- ============================================================
-- TRAIL SPIN RESULT
-- ============================================================

if trailSpinResultEvent then
	trailSpinResultEvent.OnClientEvent:Connect(function(trailName, colorRGB)
		local msg = Instance.new("TextLabel")
		msg.Size = UDim2.fromScale(0.35, 0.07)
		msg.Position = UDim2.fromScale(0.325, 0.48)
		msg.BackgroundColor3 = Color3.fromRGB(50, 30, 20)
		msg.BackgroundTransparency = 0.2
		msg.Text = "🎁 Trail: " .. (trailName or "???") .. "!"
		msg.TextColor3 = Color3.fromRGB(255, 200, 150)
		msg.TextScaled = true; msg.Font = Enum.Font.FredokaOne
		msg.Parent = hudGui
		Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 10)

		TweenService:Create(msg, TweenInfo.new(2.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromScale(0.325, 0.4),
			TextTransparency = 1,
			BackgroundTransparency = 1,
		}):Play()
		task.delay(2.7, function() msg:Destroy() end)
	end)
end

-- ============================================================
-- VICTORY
-- ============================================================

timerEvent.OnClientEvent:Connect(function(status)
	if status ~= "WIN" or not gameStarted or hasWon then return end
	hasWon = true
	gameStarted = false

	local elapsed = tick() - startTime
	local minutes = math.floor(elapsed / 60)
	local seconds = elapsed % 60
	local timeStr = string.format("%d:%04.1f", minutes, seconds)

	local victoryGui = Instance.new("ScreenGui")
	victoryGui.Name = "VictoryScreen"
	victoryGui.IgnoreGuiInset = true; victoryGui.Parent = playerGui

	local overlay = Instance.new("Frame")
	overlay.Size = UDim2.fromScale(1,1)
	overlay.BackgroundColor3 = Color3.fromRGB(0,0,0)
	overlay.BackgroundTransparency = 1; overlay.Parent = victoryGui

	TweenService:Create(overlay, TweenInfo.new(0.5), {BackgroundTransparency = 0.45}):Play()

	-- Confetti
	for i = 1, 30 do
		local confetti = Instance.new("TextLabel")
		confetti.Text = ({"🍬","🍭","🍫","🧁","✨","🎉"})[math.random(1,6)]
		confetti.TextSize = math.random(18,36)
		confetti.BackgroundTransparency = 1
		confetti.Size = UDim2.fromOffset(40,40)
		confetti.Position = UDim2.fromScale(0.5, 0.4)
		confetti.ZIndex = 10; confetti.Parent = victoryGui

		local angle = math.random()*math.pi*2
		local dist = math.random(20,60)/100
		TweenService:Create(confetti, TweenInfo.new(math.random(8,15)/10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromScale(0.5+math.cos(angle)*dist, 0.4+math.sin(angle)*dist),
			TextTransparency = 0.8,
			Rotation = math.random(-360,360),
		}):Play()
	end

	local victoryTitle = Instance.new("TextLabel")
	victoryTitle.Size = UDim2.fromScale(0,0)
	victoryTitle.Position = UDim2.fromScale(0.5, 0.18)
	victoryTitle.AnchorPoint = Vector2.new(0.5, 0.5)
	victoryTitle.BackgroundTransparency = 1
	victoryTitle.Text = "🎉 YOU WIN! 🎉"
	victoryTitle.TextColor3 = Color3.fromRGB(255,215,0)
	victoryTitle.TextScaled = true; victoryTitle.Font = Enum.Font.FredokaOne
	victoryTitle.ZIndex = 20; victoryTitle.Parent = victoryGui

	local vStroke = Instance.new("UIStroke")
	vStroke.Color = Color3.fromRGB(200,150,0); vStroke.Thickness = 3
	vStroke.Parent = victoryTitle

	task.delay(0.3, function()
		TweenService:Create(victoryTitle, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(0.7, 0.12),
		}):Play()
	end)

	local statsCard = Instance.new("Frame")
	statsCard.Size = UDim2.fromScale(0.35, 0.25)
	statsCard.Position = UDim2.fromScale(0.5, 0.42)
	statsCard.AnchorPoint = Vector2.new(0.5, 0.5)
	statsCard.BackgroundColor3 = Color3.fromRGB(30,15,40)
	statsCard.BackgroundTransparency = 0.3
	statsCard.ZIndex = 20; statsCard.Parent = victoryGui

	Instance.new("UICorner", statsCard).CornerRadius = UDim.new(0, 16)
	local scStroke = Instance.new("UIStroke")
	scStroke.Color = Color3.fromRGB(255,200,100); scStroke.Thickness = 2
	scStroke.Parent = statsCard

	local statsText = Instance.new("TextLabel")
	statsText.Size = UDim2.fromScale(0.85, 0.85)
	statsText.Position = UDim2.fromScale(0.075, 0.075)
	statsText.BackgroundTransparency = 1
	statsText.Text = string.format("⏱️  Time: %s\n\n🍬  Candies: %d\n\n✨  Sweet victory!", timeStr, candiesCollected)
	statsText.TextColor3 = Color3.fromRGB(255,255,255)
	statsText.TextScaled = true; statsText.Font = Enum.Font.GothamBold
	statsText.TextYAlignment = Enum.TextYAlignment.Center
	statsText.ZIndex = 21; statsText.Parent = statsCard

	local playAgain = Instance.new("TextButton")
	playAgain.Size = UDim2.fromScale(0,0)
	playAgain.Position = UDim2.fromScale(0.5, 0.68)
	playAgain.AnchorPoint = Vector2.new(0.5, 0.5)
	playAgain.BackgroundColor3 = Color3.fromRGB(80,220,120)
	playAgain.Text = "🍭  Play Again"
	playAgain.TextColor3 = Color3.fromRGB(255,255,255)
	playAgain.TextScaled = true; playAgain.Font = Enum.Font.FredokaOne
	playAgain.AutoButtonColor = false
	playAgain.ZIndex = 20; playAgain.Parent = victoryGui

	Instance.new("UICorner", playAgain).CornerRadius = UDim.new(0, 14)

	task.delay(0.8, function()
		TweenService:Create(playAgain, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(0.22, 0.07),
		}):Play()
	end)

	playAgain.MouseEnter:Connect(function()
		TweenService:Create(playAgain, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100,255,150)}):Play()
	end)
	playAgain.MouseLeave:Connect(function()
		TweenService:Create(playAgain, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80,220,120)}):Play()
	end)

	playAgain.MouseButton1Click:Connect(function()
		playAgain.Active = false
		TweenService:Create(overlay, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
		task.wait(0.35)
		victoryGui:Destroy()
		-- Don't go back to title — just respawn and restart timer
		hasWon = false
		startTime = tick()
		gameStarted = true
		candiesCollected = 0
		candyLabel.Text = "🍬 0"
		if not timerRunning then
			timerRunning = true
			task.spawn(function()
				while gameStarted do
					local elapsed2 = tick() - startTime
					local min2 = math.floor(elapsed2 / 60)
					local sec2 = elapsed2 % 60
					timerLabel.Text = string.format("⏱️ %d:%04.1f", min2, sec2)
					task.wait(0.05)
				end
				timerRunning = false
			end)
		end
		-- Fire server to reset checkpoint and teleport to spawn
		local startEvt = ReplicatedStorage:FindFirstChild("StartGame")
		if startEvt then startEvt:FireServer() end
	end)
end)

-- ============================================================
-- DEATH EFFECT
-- ============================================================

local function onCharacterAdded(character)
	local humanoid = character:WaitForChild("Humanoid")
	humanoid.Died:Connect(function()
		local deathOverlay = Instance.new("Frame")
		deathOverlay.Size = UDim2.fromScale(1,1)
		deathOverlay.BackgroundColor3 = Color3.fromRGB(200,30,30)
		deathOverlay.BackgroundTransparency = 0.6
		deathOverlay.ZIndex = 50; deathOverlay.Parent = hudGui

		TweenService:Create(deathOverlay, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1,
		}):Play()
		task.delay(1.1, function() if deathOverlay then deathOverlay:Destroy() end end)
	end)
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then onCharacterAdded(player.Character) end

-- ============================================================
-- 3-SECOND RESPAWN OVERLAY
-- ============================================================

respawnEvent.OnClientEvent:Connect(function(seconds)
	local rGui = Instance.new("ScreenGui")
	rGui.Name = "RespawnOverlay"
	rGui.IgnoreGuiInset = true
	rGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	rGui.Parent = playerGui

	local overlay = Instance.new("Frame")
	overlay.Size = UDim2.fromScale(1,1)
	overlay.BackgroundColor3 = Color3.fromRGB(40,0,0)
	overlay.BackgroundTransparency = 0.4
	overlay.Parent = rGui

	local fellText = Instance.new("TextLabel")
	fellText.Size = UDim2.fromScale(0.6, 0.1)
	fellText.Position = UDim2.fromScale(0.2, 0.28)
	fellText.BackgroundTransparency = 1
	fellText.Text = "💀 YOU FELL!"
	fellText.TextColor3 = Color3.fromRGB(255,80,80)
	fellText.TextScaled = true; fellText.Font = Enum.Font.FredokaOne
	fellText.Parent = rGui

	local fStroke = Instance.new("UIStroke")
	fStroke.Color = Color3.fromRGB(100,0,0); fStroke.Thickness = 3
	fStroke.Parent = fellText

	fellText.TextTransparency = 1
	TweenService:Create(fellText, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		TextTransparency = 0,
	}):Play()

	local countdownLabel = Instance.new("TextLabel")
	countdownLabel.Size = UDim2.fromScale(0.2, 0.2)
	countdownLabel.Position = UDim2.fromScale(0.4, 0.42)
	countdownLabel.BackgroundTransparency = 1
	countdownLabel.Text = tostring(seconds)
	countdownLabel.TextColor3 = Color3.fromRGB(255,255,255)
	countdownLabel.TextScaled = true; countdownLabel.Font = Enum.Font.FredokaOne
	countdownLabel.Parent = rGui

	local cStroke = Instance.new("UIStroke")
	cStroke.Color = Color3.fromRGB(255,100,100); cStroke.Thickness = 3
	cStroke.Parent = countdownLabel

	local respawnText = Instance.new("TextLabel")
	respawnText.Size = UDim2.fromScale(0.4, 0.05)
	respawnText.Position = UDim2.fromScale(0.3, 0.65)
	respawnText.BackgroundTransparency = 1
	respawnText.Text = "Respawning..."
	respawnText.TextColor3 = Color3.fromRGB(255,200,200)
	respawnText.TextTransparency = 0.3
	respawnText.TextScaled = true; respawnText.Font = Enum.Font.GothamBold
	respawnText.Parent = rGui

	for i = seconds, 1, -1 do
		countdownLabel.Text = tostring(i)

		countdownLabel.Size = UDim2.fromScale(0.15, 0.15)
		TweenService:Create(countdownLabel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(0.2, 0.2),
		}):Play()

		countdownLabel.TextColor3 = Color3.fromRGB(255,100,100)
		TweenService:Create(countdownLabel, TweenInfo.new(0.5), {
			TextColor3 = Color3.fromRGB(255,255,255),
		}):Play()

		task.wait(1)
	end

	TweenService:Create(overlay, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
	TweenService:Create(fellText, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
	TweenService:Create(countdownLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
	TweenService:Create(respawnText, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
	task.delay(0.5, function() rGui:Destroy() end)
end)

print("[CandyRun] Client HUD loaded!")
]]></string>
        </Properties>
        <Item class="LocalScript" referent="14">
          <Properties>
            <string name="Name">Boombox</string>
            <string name="Source"><![CDATA[--[[
	Boombox Client - Song ID interface
	When the Boombox tool is equipped and LMB is clicked, opens a small UI
	to type a Roblox song ID. Sends the ID to the server to play.
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local boomboxEvent = ReplicatedStorage:WaitForChild("BoomboxPlay", 10)

local boomboxEquipped = false
local boomboxUiOpen = false
local currentGui = nil

-- ============================================================
-- BUILD THE BOOMBOX UI
-- ============================================================

local function createBoomboxUI()
	if currentGui then currentGui:Destroy() end

	local gui = Instance.new("ScreenGui")
	gui.Name = "BoomboxUI"
	gui.ResetOnSpawn = false
	gui.IgnoreGuiInset = true
	gui.Parent = playerGui

	-- Small centered panel
	local panel = Instance.new("Frame")
	panel.Size = UDim2.fromScale(0.26, 0.18)
	panel.Position = UDim2.fromScale(0.37, 0.4)
	panel.BackgroundColor3 = Color3.fromRGB(30, 25, 40)
	panel.BackgroundTransparency = 0.05
	panel.Parent = gui
	Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 16)

	local panelStroke = Instance.new("UIStroke")
	panelStroke.Color = Color3.fromRGB(255, 80, 200); panelStroke.Thickness = 2
	panelStroke.Parent = panel

	-- Title
	local title = Instance.new("TextLabel")
	title.Size = UDim2.fromScale(0.8, 0.22)
	title.Position = UDim2.fromScale(0.1, 0.02)
	title.BackgroundTransparency = 1
	title.Text = "📻 BOOMBOX"
	title.TextColor3 = Color3.fromRGB(255, 120, 220)
	title.TextScaled = true; title.Font = Enum.Font.FredokaOne
	title.Parent = panel

	-- Song ID input box
	local inputBox = Instance.new("TextBox")
	inputBox.Size = UDim2.fromScale(0.7, 0.25)
	inputBox.Position = UDim2.fromScale(0.05, 0.3)
	inputBox.BackgroundColor3 = Color3.fromRGB(50, 40, 60)
	inputBox.Text = ""
	inputBox.PlaceholderText = "Enter Song ID..."
	inputBox.PlaceholderColor3 = Color3.fromRGB(140, 120, 160)
	inputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	inputBox.TextScaled = true; inputBox.Font = Enum.Font.GothamBold
	inputBox.ClearTextOnFocus = true
	inputBox.Parent = panel
	Instance.new("UICorner", inputBox).CornerRadius = UDim.new(0, 8)

	-- Play button
	local playBtn = Instance.new("TextButton")
	playBtn.Size = UDim2.fromScale(0.2, 0.25)
	playBtn.Position = UDim2.fromScale(0.77, 0.3)
	playBtn.BackgroundColor3 = Color3.fromRGB(80, 200, 100)
	playBtn.Text = "▶"
	playBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	playBtn.TextScaled = true; playBtn.Font = Enum.Font.FredokaOne
	playBtn.AutoButtonColor = false
	playBtn.Parent = panel
	Instance.new("UICorner", playBtn).CornerRadius = UDim.new(0, 8)

	-- Stop button
	local stopBtn = Instance.new("TextButton")
	stopBtn.Size = UDim2.fromScale(0.44, 0.22)
	stopBtn.Position = UDim2.fromScale(0.05, 0.62)
	stopBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	stopBtn.Text = "⏹ Stop"
	stopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	stopBtn.TextScaled = true; stopBtn.Font = Enum.Font.FredokaOne
	stopBtn.AutoButtonColor = false
	stopBtn.Parent = panel
	Instance.new("UICorner", stopBtn).CornerRadius = UDim.new(0, 8)

	-- Close button
	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.fromScale(0.44, 0.22)
	closeBtn.Position = UDim2.fromScale(0.53, 0.62)
	closeBtn.BackgroundColor3 = Color3.fromRGB(80, 70, 100)
	closeBtn.Text = "✕ Close"
	closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	closeBtn.TextScaled = true; closeBtn.Font = Enum.Font.FredokaOne
	closeBtn.AutoButtonColor = false
	closeBtn.Parent = panel
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 8)

	-- Status label
	local statusLabel = Instance.new("TextLabel")
	statusLabel.Size = UDim2.fromScale(0.9, 0.12)
	statusLabel.Position = UDim2.fromScale(0.05, 0.87)
	statusLabel.BackgroundTransparency = 1
	statusLabel.Text = ""
	statusLabel.TextColor3 = Color3.fromRGB(180, 255, 180)
	statusLabel.TextScaled = true; statusLabel.Font = Enum.Font.Gotham
	statusLabel.Parent = panel

	-- Hover effects
	local function hoverEffect(btn, normalColor, hoverColor)
		btn.MouseEnter:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = hoverColor}):Play()
		end)
		btn.MouseLeave:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = normalColor}):Play()
		end)
	end
	hoverEffect(playBtn, Color3.fromRGB(80, 200, 100), Color3.fromRGB(100, 240, 130))
	hoverEffect(stopBtn, Color3.fromRGB(200, 60, 60), Color3.fromRGB(240, 80, 80))
	hoverEffect(closeBtn, Color3.fromRGB(80, 70, 100), Color3.fromRGB(110, 95, 140))

	-- Play
	playBtn.MouseButton1Click:Connect(function()
		local text = inputBox.Text:gsub("%s", "")
		local songId = tonumber(text)
		if songId and songId > 0 then
			if boomboxEvent then
				boomboxEvent:FireServer(songId)
			end
			statusLabel.Text = "🎵 Playing ID: " .. text
			statusLabel.TextColor3 = Color3.fromRGB(180, 255, 180)
			TweenService:Create(playBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 255, 100)}):Play()
			task.wait(0.15)
			TweenService:Create(playBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 200, 100)}):Play()
		else
			statusLabel.Text = "❌ Enter a valid number!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 120, 120)
		end
	end)

	-- Also play on Enter key in the text box
	inputBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			playBtn.MouseButton1Click:Fire()
		end
	end)

	-- Stop
	stopBtn.MouseButton1Click:Connect(function()
		if boomboxEvent then
			boomboxEvent:FireServer(0)
		end
		statusLabel.Text = "⏹ Stopped"
		statusLabel.TextColor3 = Color3.fromRGB(255, 180, 180)
	end)

	-- Close
	closeBtn.MouseButton1Click:Connect(function()
		boomboxUiOpen = false
		gui:Destroy()
		currentGui = nil
	end)

	-- Animate in
	panel.Size = UDim2.fromScale(0, 0)
	panel.Position = UDim2.fromScale(0.5, 0.5)
	TweenService:Create(panel, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(0.26, 0.18),
		Position = UDim2.fromScale(0.37, 0.4),
	}):Play()

	currentGui = gui
	boomboxUiOpen = true
end

-- ============================================================
-- TOOL DETECTION
-- ============================================================

local function onCharacterAdded(char)
	-- Watch for boombox equip/unequip
	char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") and child.Name == "Boombox" then
			boomboxEquipped = true
		end
	end)
	char.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") and child.Name == "Boombox" then
			boomboxEquipped = false
			-- Close UI when unequipped
			if currentGui then
				boomboxUiOpen = false
				currentGui:Destroy()
				currentGui = nil
			end
		end
	end)
end

if player.Character then onCharacterAdded(player.Character) end
player.CharacterAdded:Connect(onCharacterAdded)

-- Listen for Activated on any Boombox tool (fires on LMB click while equipped)
local function watchForBoombox()
	local function hookTool(tool)
		if tool:IsA("Tool") and tool.Name == "Boombox" then
			tool.Activated:Connect(function()
				if boomboxUiOpen then
					-- Toggle off
					boomboxUiOpen = false
					if currentGui then currentGui:Destroy(); currentGui = nil end
				else
					createBoomboxUI()
				end
			end)
		end
	end

	-- Hook existing tools
	for _, item in player.Backpack:GetChildren() do hookTool(item) end
	player.Backpack.ChildAdded:Connect(hookTool)

	if player.Character then
		for _, item in player.Character:GetChildren() do hookTool(item) end
		player.Character.ChildAdded:Connect(hookTool)
	end
	player.CharacterAdded:Connect(function(char)
		char.ChildAdded:Connect(hookTool)
	end)
end

watchForBoombox()

print("[CandyRun] Boombox client loaded!")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="15">
          <Properties>
            <string name="Name">GrapplingGun</string>
            <string name="Source"><![CDATA[--[[
	Grapple Gun - Client Controller
	When the Grapple Gun tool is equipped + activated (click/tap),
	fires GrappleShoot to server with origin + look direction.
	Visual feedback: crosshair, cooldown indicator, hit flash.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local camera = workspace.CurrentCamera

local grappleShootEvent = ReplicatedStorage:WaitForChild("GrappleShoot")
local grappleHitEvent = ReplicatedStorage:WaitForChild("GrappleHit")

-- ============================================================
-- COOLDOWN STATE
-- ============================================================

local COOLDOWN = 2
local lastFireTime = 0

-- ============================================================
-- CROSSHAIR UI (only visible when grapple gun equipped)
-- ============================================================

local crosshairGui = Instance.new("ScreenGui")
crosshairGui.Name = "GrappleCrosshair"
crosshairGui.ResetOnSpawn = false
crosshairGui.IgnoreGuiInset = false
crosshairGui.Enabled = false
crosshairGui.Parent = playerGui

local crosshair = Instance.new("TextLabel")
crosshair.Size = UDim2.fromOffset(30, 30)
crosshair.Position = UDim2.fromScale(0.5, 0.5)
crosshair.AnchorPoint = Vector2.new(0.5, 0.5)
crosshair.BackgroundTransparency = 1
crosshair.Text = "◎"
crosshair.TextColor3 = Color3.fromRGB(255, 80, 80)
crosshair.TextSize = 28
crosshair.Font = Enum.Font.GothamBold
crosshair.Parent = crosshairGui

local cooldownBar = Instance.new("Frame")
cooldownBar.Size = UDim2.fromScale(0.08, 0.006)
cooldownBar.Position = UDim2.fromScale(0.46, 0.54)
cooldownBar.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
cooldownBar.BackgroundTransparency = 0.3
cooldownBar.Parent = crosshairGui
Instance.new("UICorner", cooldownBar).CornerRadius = UDim.new(0, 3)

-- ============================================================
-- TOOL DETECTION
-- ============================================================

local grappleEquipped = false

local function onCharacterAdded(character)
	character.ChildAdded:Connect(function(child)
		if child:IsA("Tool") and child.Name == "Grapple Gun" then
			grappleEquipped = true
			crosshairGui.Enabled = true

			child.Activated:Connect(function()
				if not grappleEquipped then return end
				if tick() - lastFireTime < COOLDOWN then return end
				lastFireTime = tick()

				-- Get aim direction from camera
				local camCF = camera.CFrame
				local origin = camCF.Position + camCF.LookVector * 3
				local direction = camCF.LookVector

				-- Fire to server
				grappleShootEvent:FireServer(origin, direction)

				-- Visual feedback: crosshair flash
				crosshair.TextColor3 = Color3.fromRGB(255, 255, 100)
				TweenService:Create(crosshair, TweenInfo.new(0.3), {
					TextColor3 = Color3.fromRGB(255, 80, 80),
				}):Play()

				-- Cooldown bar animation
				cooldownBar.Size = UDim2.fromScale(0.08, 0.006)
				cooldownBar.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
				TweenService:Create(cooldownBar, TweenInfo.new(COOLDOWN, Enum.EasingStyle.Linear), {
					Size = UDim2.fromScale(0.08, 0.006),
					BackgroundColor3 = Color3.fromRGB(255, 80, 80),
				}):Play()
				-- Shrink then grow back
				cooldownBar.Size = UDim2.fromScale(0, 0.006)
				TweenService:Create(cooldownBar, TweenInfo.new(COOLDOWN, Enum.EasingStyle.Linear), {
					Size = UDim2.fromScale(0.08, 0.006),
				}):Play()
			end)

			child.Unequipped:Connect(function()
				grappleEquipped = false
				crosshairGui.Enabled = false
			end)
		end
	end)

	character.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") and child.Name == "Grapple Gun" then
			grappleEquipped = false
			crosshairGui.Enabled = false
		end
	end)
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then onCharacterAdded(player.Character) end

-- ============================================================
-- HIT FEEDBACK
-- ============================================================

grappleHitEvent.OnClientEvent:Connect(function(status, data)
	if status == "hit" then
		-- Screen flash on successful grapple
		local flash = Instance.new("Frame")
		flash.Size = UDim2.fromScale(1, 1)
		flash.BackgroundColor3 = Color3.fromRGB(255, 220, 100)
		flash.BackgroundTransparency = 0.7
		flash.ZIndex = 50
		flash.Parent = crosshairGui

		TweenService:Create(flash, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1,
		}):Play()
		task.delay(0.5, function() flash:Destroy() end)

		-- Crosshair goes green briefly
		crosshair.TextColor3 = Color3.fromRGB(100, 255, 100)
		TweenService:Create(crosshair, TweenInfo.new(0.5), {
			TextColor3 = Color3.fromRGB(255, 80, 80),
		}):Play()
	end
end)

print("[CandyRun] Grapple Gun client controller loaded!")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="16">
          <Properties>
            <string name="Name">MagicCarpet</string>
            <string name="Source"><![CDATA[--[[
	Magic Carpet - Client Flight Controller
	Equip carpet tool → press M1 (click) → mount animation → sit + fly.
	Press M1 again to dismount.
	WASD = horizontal, Space = ascend, LeftControl = descend.
	Leaves a rainbow trail behind.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local carpetFlyEvent = ReplicatedStorage:WaitForChild("CarpetFlyToggle")

local isFlying = false
local isMounting = false
local carpetEquipped = false
local FLY_SPEED = 80
local FLY_ASCEND_SPEED = 50
local FLY_DESCEND_SPEED = 45
local MOUNT_DURATION = 1.2

-- Track input
local keysDown = {}

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	keysDown[input.KeyCode] = true
end)

UserInputService.InputEnded:Connect(function(input)
	keysDown[input.KeyCode] = nil
end)

local flyConnection = nil
local trailPart = nil
local trail = nil

-- ============================================================
-- TRAIL (rainbow trail behind the carpet)
-- ============================================================

local function createTrail(character)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	-- Trail attachment points
	local att0 = Instance.new("Attachment")
	att0.Name = "CarpetTrailAtt0"
	att0.Position = Vector3.new(0, -2, 2)
	att0.Parent = rootPart

	local att1 = Instance.new("Attachment")
	att1.Name = "CarpetTrailAtt1"
	att1.Position = Vector3.new(0, -2, -2)
	att1.Parent = rootPart

	trail = Instance.new("Trail")
	trail.Name = "CarpetTrail"
	trail.Attachment0 = att0
	trail.Attachment1 = att1
	trail.Lifetime = 1.5
	trail.MinLength = 0.1
	trail.FaceCamera = true
	trail.LightEmission = 0.5
	trail.LightInfluence = 0.3
	trail.Enabled = true

	-- Rainbow color
	trail.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 50, 50)),
		ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 160, 0)),
		ColorSequenceKeypoint.new(0.33, Color3.fromRGB(255, 255, 50)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(50, 255, 50)),
		ColorSequenceKeypoint.new(0.67, Color3.fromRGB(50, 150, 255)),
		ColorSequenceKeypoint.new(0.83, Color3.fromRGB(130, 50, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 50, 255)),
	})

	trail.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.1),
		NumberSequenceKeypoint.new(0.5, 0.3),
		NumberSequenceKeypoint.new(1, 1),
	})

	trail.WidthScale = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.5, 0.6),
		NumberSequenceKeypoint.new(1, 0),
	})

	trail.Parent = rootPart
	return att0, att1
end

local function destroyTrail(character)
	if not character then return end
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if rootPart then
		local t = rootPart:FindFirstChild("CarpetTrail")
		if t then t:Destroy() end
		local a0 = rootPart:FindFirstChild("CarpetTrailAtt0")
		if a0 then a0:Destroy() end
		local a1 = rootPart:FindFirstChild("CarpetTrailAtt1")
		if a1 then a1:Destroy() end
	end
	trail = nil
end

-- ============================================================
-- MOUNT ANIMATION
-- ============================================================

local function playMountAnimation()
	isMounting = true

	local character = player.Character
	if not character then isMounting = false; return false end
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")
	if not rootPart or not humanoid then isMounting = false; return false end

	-- Force sit
	humanoid.Sit = true
	local origSpeed = humanoid.WalkSpeed
	humanoid.WalkSpeed = 0
	humanoid.JumpPower = 0

	-- Anti-gravity during mount
	local mountForce = Instance.new("BodyForce")
	mountForce.Name = "MountAntiGrav"
	local mass = 0
	for _, part in character:GetDescendants() do
		if part:IsA("BasePart") then mass += part:GetMass() end
	end
	mountForce.Force = Vector3.new(0, mass * workspace.Gravity, 0)
	mountForce.Parent = rootPart

	-- Gentle rise
	local mountVel = Instance.new("BodyVelocity")
	mountVel.Name = "MountVelocity"
	mountVel.MaxForce = Vector3.new(50000, 50000, 50000)
	mountVel.Velocity = Vector3.new(0, 5, 0)
	mountVel.Parent = rootPart

	-- Gyro for orientation
	local mountGyro = Instance.new("BodyGyro")
	mountGyro.Name = "MountGyro"
	mountGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
	mountGyro.P = 5000; mountGyro.D = 300
	mountGyro.Parent = rootPart

	-- Mount sparkles
	local mountParticles = Instance.new("ParticleEmitter")
	mountParticles.Name = "MountParticles"
	mountParticles.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 220, 100)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 100, 200)),
	})
	mountParticles.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.8), NumberSequenceKeypoint.new(1, 0),
	})
	mountParticles.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1),
	})
	mountParticles.Lifetime = NumberRange.new(0.4, 0.8)
	mountParticles.Rate = 50; mountParticles.Speed = NumberRange.new(3, 8)
	mountParticles.SpreadAngle = Vector2.new(180, 180)
	mountParticles.Parent = rootPart

	-- Animate over mount duration
	local steps = math.ceil(MOUNT_DURATION * 30)
	for step = 1, steps do
		if not isMounting then break end
		local t = step / steps
		local camLook = camera.CFrame.LookVector
		local flatLook = Vector3.new(camLook.X, 0, camLook.Z)
		if flatLook.Magnitude > 0.1 then
			mountGyro.CFrame = CFrame.lookAt(Vector3.zero, flatLook.Unit)
		end
		mountVel.Velocity = Vector3.new(0, 5 * (1 - t * 0.8), 0)
		task.wait(1/30)
	end

	-- Clean up mount forces
	if mountVel and mountVel.Parent then mountVel:Destroy() end
	if mountGyro and mountGyro.Parent then mountGyro:Destroy() end
	if mountForce and mountForce.Parent then mountForce:Destroy() end
	if mountParticles and mountParticles.Parent then
		mountParticles.Rate = 0
		task.delay(1, function()
			if mountParticles and mountParticles.Parent then mountParticles:Destroy() end
		end)
	end

	humanoid.WalkSpeed = origSpeed
	isMounting = false
	return true
end

-- ============================================================
-- FLIGHT
-- ============================================================

local function startFlying()
	if isFlying or isMounting then return end

	-- Mount animation first
	local mounted = playMountAnimation()
	if not mounted then return end
	if not player.Character then return end

	isFlying = true

	local character = player.Character
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")
	if not rootPart or not humanoid then isFlying = false; return end

	-- Keep sitting
	humanoid.Sit = true

	-- BodyGyro
	local gyro = Instance.new("BodyGyro")
	gyro.Name = "CarpetGyro"
	gyro.MaxTorque = Vector3.new(400000, 400000, 400000)
	gyro.P = 10000; gyro.D = 500
	gyro.Parent = rootPart

	-- BodyVelocity
	local bv = Instance.new("BodyVelocity")
	bv.Name = "CarpetVelocity"
	bv.MaxForce = Vector3.new(100000, 100000, 100000)
	bv.Velocity = Vector3.new(0, 0, 0)
	bv.P = 5000
	bv.Parent = rootPart

	-- Anti-gravity
	local antigrav = Instance.new("BodyForce")
	antigrav.Name = "CarpetAntiGrav"
	local mass = 0
	for _, part in character:GetDescendants() do
		if part:IsA("BasePart") then mass += part:GetMass() end
	end
	antigrav.Force = Vector3.new(0, mass * workspace.Gravity, 0)
	antigrav.Parent = rootPart

	-- Flight particles
	local particles = Instance.new("ParticleEmitter")
	particles.Name = "CarpetParticles"
	particles.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 220, 100)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 150, 50)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 100, 200)),
	})
	particles.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.4), NumberSequenceKeypoint.new(1, 0),
	})
	particles.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.3), NumberSequenceKeypoint.new(1, 1),
	})
	particles.Lifetime = NumberRange.new(0.5, 1)
	particles.Rate = 20; particles.Speed = NumberRange.new(1, 3)
	particles.SpreadAngle = Vector2.new(30, 30)
	particles.Acceleration = Vector3.new(0, -5, 0)
	particles.Parent = rootPart

	-- Create rainbow trail
	createTrail(character)

	-- Flight loop
	flyConnection = RunService.Heartbeat:Connect(function()
		if not isFlying or not rootPart or not rootPart.Parent then return end

		local camCF = camera.CFrame
		local lookVector = camCF.LookVector
		local rightVector = camCF.RightVector

		local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
		local flatRight = Vector3.new(rightVector.X, 0, rightVector.Z).Unit

		local moveDir = Vector3.new(0, 0, 0)

		if keysDown[Enum.KeyCode.W] then moveDir += flatLook end
		if keysDown[Enum.KeyCode.S] then moveDir -= flatLook end
		if keysDown[Enum.KeyCode.D] then moveDir += flatRight end
		if keysDown[Enum.KeyCode.A] then moveDir -= flatRight end

		-- Space = ascend, LeftControl = descend
		if keysDown[Enum.KeyCode.Space] then
			moveDir += Vector3.new(0, 1, 0) * (FLY_ASCEND_SPEED / FLY_SPEED)
		end
		if keysDown[Enum.KeyCode.LeftControl] then
			moveDir -= Vector3.new(0, 1, 0) * (FLY_DESCEND_SPEED / FLY_SPEED)
		end

		if moveDir.Magnitude > 0.01 then
			moveDir = moveDir.Unit * FLY_SPEED
		else
			moveDir = Vector3.new(0, 0, 0)
		end

		bv.Velocity = moveDir

		if moveDir.Magnitude > 1 then
			local flatMove = Vector3.new(moveDir.X, 0, moveDir.Z)
			if flatMove.Magnitude > 0.1 then
				gyro.CFrame = CFrame.lookAt(Vector3.zero, flatMove)
			end
		else
			local flatCamLook = Vector3.new(lookVector.X, 0, lookVector.Z)
			if flatCamLook.Magnitude > 0.1 then
				gyro.CFrame = CFrame.lookAt(Vector3.zero, flatCamLook)
			end
		end

		-- Tilt for visual flair
		local tiltAngle = 0
		if keysDown[Enum.KeyCode.W] then tiltAngle = -0.18 end
		if keysDown[Enum.KeyCode.S] then tiltAngle = 0.12 end
		gyro.CFrame = gyro.CFrame * CFrame.Angles(tiltAngle, 0, 0)

		-- Keep sit
		if humanoid and not humanoid.Sit then humanoid.Sit = true end
	end)
end

local function stopFlying()
	isMounting = false
	if not isFlying then return end
	isFlying = false

	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end

	local character = player.Character
	if not character then return end
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")

	-- Destroy trail
	destroyTrail(character)

	if rootPart then
		for _, name in ipairs({"CarpetGyro","CarpetVelocity","CarpetAntiGrav","CarpetParticles","MountAntiGrav","MountVelocity","MountGyro","MountParticles"}) do
			local obj = rootPart:FindFirstChild(name)
			if obj then obj:Destroy() end
		end
	end
	if humanoid then
		humanoid.Sit = false
		humanoid.JumpPower = 60
	end
end

-- ============================================================
-- M1 TOGGLE: Click to mount/dismount (server sends equip event)
-- ============================================================

-- Server fires CarpetFlyToggle(true) on equip, (false) on unequip.
-- We intercept: on equip, DON'T fly yet — wait for M1 click.
-- On unequip, always stop.

local waitingForClick = false

carpetFlyEvent.OnClientEvent:Connect(function(enabled)
	if enabled then
		-- Carpet equipped — wait for M1 to mount
		carpetEquipped = true
		waitingForClick = true
		-- Don't start flying yet
	else
		-- Carpet unequipped — stop everything
		carpetEquipped = false
		waitingForClick = false
		stopFlying()
	end
end)

-- Listen for M1 click while carpet is equipped
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	if not carpetEquipped then return end

	if waitingForClick and not isFlying and not isMounting then
		-- M1 pressed with carpet equipped: mount and fly
		waitingForClick = false
		task.spawn(startFlying)
	elseif isFlying then
		-- M1 pressed while flying: dismount
		stopFlying()
		waitingForClick = true -- can click again to remount
	end
end)

-- Clean up on death
local function onCharacterAdded(character)
	character:WaitForChild("Humanoid").Died:Connect(function()
		stopFlying()
		carpetEquipped = false
		waitingForClick = false
	end)
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then
	onCharacterAdded(player.Character)
end

print("[CandyRun] Magic Carpet loaded! M1 to mount/dismount, speed 80, rainbow trail.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="17">
          <Properties>
            <string name="Name">ShiftLock</string>
            <string name="Source"><![CDATA[--[[
	Candy Run - Shift Lock Toggle
	Press Left Shift to toggle mouse-lock (third-person over-shoulder camera).
	Shows a small UI indicator when shift lock is active.
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local camera = workspace.CurrentCamera
local mouse = player:GetMouse()

-- ============================================================
-- STATE
-- ============================================================

local shiftLocked = false
local SHIFT_LOCK_OFFSET = Vector3.new(2, 0.6, 0)  -- over-right-shoulder

-- ============================================================
-- SHIFT LOCK INDICATOR UI
-- ============================================================

local indicatorGui = Instance.new("ScreenGui")
indicatorGui.Name = "ShiftLockIndicator"
indicatorGui.ResetOnSpawn = false
indicatorGui.IgnoreGuiInset = false
indicatorGui.Parent = playerGui

local indicator = Instance.new("Frame")
indicator.Size = UDim2.fromScale(0.06, 0.04)
indicator.Position = UDim2.fromScale(0.02, 0.02)
indicator.BackgroundColor3 = Color3.fromRGB(30, 15, 40)
indicator.BackgroundTransparency = 0.5
indicator.Visible = false
indicator.Parent = indicatorGui

Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 8)

local indicatorStroke = Instance.new("UIStroke")
indicatorStroke.Color = Color3.fromRGB(255, 150, 200)
indicatorStroke.Thickness = 1.5
indicatorStroke.Parent = indicator

local indicatorLabel = Instance.new("TextLabel")
indicatorLabel.Size = UDim2.fromScale(0.9, 0.8)
indicatorLabel.Position = UDim2.fromScale(0.05, 0.1)
indicatorLabel.BackgroundTransparency = 1
indicatorLabel.Text = "🔒 Shift Lock"
indicatorLabel.TextColor3 = Color3.fromRGB(255, 200, 230)
indicatorLabel.TextScaled = true
indicatorLabel.Font = Enum.Font.GothamBold
indicatorLabel.Parent = indicator

-- Pop-in animation helper
local function showIndicator()
	indicator.Visible = true
	indicator.Size = UDim2.fromScale(0.03, 0.02)
	TweenService:Create(indicator, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(0.06, 0.04),
	}):Play()
	TweenService:Create(indicatorStroke, TweenInfo.new(0.2), {
		Color = Color3.fromRGB(100, 255, 150),
	}):Play()
end

local function hideIndicator()
	TweenService:Create(indicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.fromScale(0.03, 0.02),
	}):Play()
	TweenService:Create(indicatorStroke, TweenInfo.new(0.2), {
		Color = Color3.fromRGB(255, 150, 200),
	}):Play()
	task.delay(0.2, function()
		if not shiftLocked then
			indicator.Visible = false
		end
	end)
end

-- ============================================================
-- TOGGLE ON SHIFT PRESS
-- ============================================================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.LeftShift then
		shiftLocked = not shiftLocked

		if shiftLocked then
			-- Lock mouse to center
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			showIndicator()
		else
			-- Unlock mouse
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			hideIndicator()
		end
	end
end)

-- ============================================================
-- SHIFT LOCK CAMERA BEHAVIOR
-- ============================================================

RunService.RenderStepped:Connect(function()
	local character = player.Character
	if not character then return end
	local humanoid = character:FindFirstChild("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return end

	if shiftLocked then
		-- Keep mouse locked
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

		-- Offset camera to right shoulder
		humanoid.CameraOffset = humanoid.CameraOffset:Lerp(SHIFT_LOCK_OFFSET, 0.15)

		-- Rotate character to face camera direction
		local cameraLook = camera.CFrame.LookVector
		local flatLook = Vector3.new(cameraLook.X, 0, cameraLook.Z).Unit

		if flatLook.Magnitude > 0.1 then
			local targetCF = CFrame.lookAt(rootPart.Position, rootPart.Position + flatLook)
			rootPart.CFrame = rootPart.CFrame:Lerp(targetCF, 0.2)
		end
	else
		-- Let the character script handle camera offset (smooth bob etc.)
		-- Don't override here — the character script lerps CameraOffset
	end
end)

-- Reset mouse behavior when character respawns
player.CharacterAdded:Connect(function()
	if not shiftLocked then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end
end)

print("[CandyRun] Shift Lock loaded! Press Left Shift to toggle.")
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
  <Item class="Workspace" referent="18">
    <Properties>
      <string name="Name">Workspace</string>
      <float name="Gravity">196.2</float>
      <bool name="NeedsPivotMigration">false</bool>
    </Properties>
  </Item>
</roblox>